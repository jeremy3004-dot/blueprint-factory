{
  "name": "himalayan-passage",
  "version": "0.1.0",
  "private": true,
  "description": "Premium Nepal trekking web app with route discovery, booking UX, and AI concierge.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src next.config.ts eslint.config.mjs postcss.config.mjs --max-warnings=0",
    "test": "node --experimental-strip-types --test src/lib/*.test.ts",
    "ingest:crawl": "node scripts/ingestion/crawl-operator-sources.mjs",
    "ingest:docling": "node scripts/ingestion/docling-convert.mjs",
    "cf:dev": "npx wrangler dev --config cloudflare/ops-api/wrangler.toml",
    "cf:deploy": "npx wrangler deploy --config cloudflare/ops-api/wrangler.toml",
    "cf:migrate:local": "npx wrangler d1 migrations apply gptrek-ops --local --config cloudflare/ops-api/wrangler.toml",
    "cf:migrate:remote": "npx wrangler d1 migrations apply gptrek-ops --remote --config cloudflare/ops-api/wrangler.toml"
  },
  "keywords": [
    "nepal",
    "trekking",
    "travel",
    "nextjs",
    "vercel",
    "supabase"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@hookform/resolvers": "^5.2.2",
    "@payloadcms/db-postgres": "^3.84.1",
    "@payloadcms/next": "^3.84.1",
    "@payloadcms/richtext-lexical": "^3.84.1",
    "@refinedev/core": "^5.0.12",
    "@supabase/supabase-js": "^2.103.0",
    "clsx": "^2.1.1",
    "crawlee": "^3.16.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.38.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.8.0",
    "next": "^16.2.3",
    "openai": "^6.34.0",
    "payload": "^3.84.1",
    "posthog-js": "^1.372.9",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.72.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2"
  },
  "overrides": {
    "dompurify": "3.4.2",
    "esbuild": "0.25.12",
    "file-type": "21.3.4",
    "postcss": "8.5.14",
    "uuid": "11.1.1"
  }
}
