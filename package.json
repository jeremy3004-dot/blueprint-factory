{
  "name": "blueprint-factory",
  "private": true,
  "type": "module",
  "scripts": {
    "blueprint": "tsx factory/scripts/blueprint.ts",
    "blueprint:run": "tsx factory/scripts/blueprint.ts run",
    "blueprint:status": "tsx factory/scripts/blueprint.ts status",
    "blueprint:new": "tsx factory/scripts/blueprint.ts new",
    "blueprint:adopt": "tsx factory/scripts/blueprint.ts adopt",
    "blueprint:capture": "tsx factory/scripts/blueprint.ts capture",
    "blueprint:art": "tsx factory/scripts/blueprint.ts art",
    "blueprint:check": "tsx factory/scripts/blueprint.ts check",
    "blueprint:compare": "tsx factory/scripts/blueprint.ts compare",
    "blueprint:verify": "tsx factory/scripts/blueprint.ts verify",
    "blueprint:tokens": "tsx factory/scripts/blueprint.ts tokens",
    "blueprint:copydeck": "tsx factory/scripts/blueprint.ts copydeck",
    "blueprint:screenshots": "tsx factory/scripts/blueprint.ts screenshots",
    "blueprint:motion": "tsx factory/scripts/blueprint.ts motion",
    "blueprint:beauty": "tsx factory/scripts/blueprint.ts beauty",
    "blueprint:deploy": "tsx factory/scripts/blueprint.ts deploy",
    "test": "tsx --test factory/scripts/*.test.ts"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "latest",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "tsx": "latest",
    "typescript": "latest"
  }
}
